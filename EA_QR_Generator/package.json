{
  "name": "ea-qr-generator",
  "version": "1.0.0",
  "description": "Générateur de QR Code pour les sessions de shooting Europ Assistance",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --mac"
  },
  "build": {
    "appId": "com.studioriad.qrgenerator",
    "productName": "EA QR Generator",
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dmg"
      ],
      "icon": "icon.icns"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "style.css",
      "package.json",
      "node_modules/**/*"
    ]
  },
  "author": "Antigravity",
  "license": "ISC",
  "devDependencies": {
    "electron": "^34.3.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "qrcode": "^1.5.3"
  }
}
